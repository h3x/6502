1040 DATA "YOU ARE IN AN UNDERGROUND LAKE",0,2,0,0
1050 DATA "YOU ARE ON A HILLTOP",1,0,6,3
1061 DATA "YOU ARE IN A SMALL VILLAGE",7,0,0,5
1070 DATA "YOU ARE INSIDE A HOUSE",0,6,8,0
1080 DATA "YOU ARE IN A TREASURE ROOM",9,0,0,7
1090 DATA "YOU ARE IN A NARROW PASSAGE",10,8,0,0
1100 DATA "YOU ARE AT A DEAD END",0,9,0,0
