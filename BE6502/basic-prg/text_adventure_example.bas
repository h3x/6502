10 REM === SIMPLE DATA-DRIVEN TEXT ADVENTURE ===

20 DIM R$(10)
30 DIM N(10), S(10), E(10), W(10)

40 REM LOAD ROOMS
50 FOR I = 1 TO 10
60 READ R$(I), N(I), S(I), E(I), W(I)
70 NEXT I

80 REM START ROOM
90 R = 1

100 REM MAIN LOOP
110 PRINT
120 PRINT R$(R)

130 INPUT "DIRECTION (N,S,E,W,Q)"; D$

140 IF D$="Q" THEN END

150 IF D$="N" THEN GOSUB 300
160 IF D$="S" THEN GOSUB 310
170 IF D$="E" THEN GOSUB 320
180 IF D$="W" THEN GOSUB 330

190 GOTO 110

200 REM INVALID MOVE
210 PRINT "YOU CAN'T GO THAT WAY."
220 RETURN

300 REM NORTH
305 IF N(R)=0 THEN GOSUB 200
307 IF N(R)<>0 THEN R=N(R)
308 RETURN

310 REM SOUTH
315 IF S(R)=0 THEN GOSUB 200
316 IF S(R)<>0 THEN R=S(R)
317 RETURN

320 REM EAST
325 IF E(R)=0 THEN GOSUB 200
326 IF E(R) <> 0 THEN R=E(R)
327 RETURN

330 REM WEST
335 IF W(R)=0 THEN GOSUB 200 
336 IF W(R)<>0 THEN R=W(R)
337 RETURN

1000 REM === ROOM DATA ===
1010 DATA "YOU ARE AT THE ENTRANCE OF A CAVE",2,0,3,0
